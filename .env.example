# SentinelMap Environment Configuration
# Copy to .env and modify as needed: cp .env.example .env

# ---------------------------------------------------------------------------
# Data mode
# ---------------------------------------------------------------------------
# Live (default)     — real AIS via AISStream.io + real ADS-B via Airplanes.live
# Simulated          — deterministic simulated vessels and aircraft, no external calls
# Hybrid             — live data with simulated fallback on connection failure
SENTINELMAP_DATA_MODE=Live

# Per-source mode overrides (optional, defaults to SENTINELMAP_DATA_MODE)
# SENTINELMAP_AIS_MODE=live
# SENTINELMAP_ADSB_MODE=live

# ---------------------------------------------------------------------------
# API keys
# ---------------------------------------------------------------------------
# Required for Live AIS mode (free key from https://aisstream.io)
# AISSTREAM_API_KEY=your-key-here

# ADS-B live mode requires no API key (Airplanes.live is public)

# ---------------------------------------------------------------------------
# Seed accounts
# ---------------------------------------------------------------------------
# Password for seeded demo accounts (minimum 12 characters, NIST 800-63B compliant)
# SENTINELMAP_SEED_PASSWORD=SentinelDemo123!

# ---------------------------------------------------------------------------
# Alert thresholds
# ---------------------------------------------------------------------------
# AIS dark detection timeout in seconds (default: 900, demo: 30)
# AIS_DARK_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_dev_password
POSTGRES_DB=sentinelmap

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ---------------------------------------------------------------------------
# JWT (RS256)
# Generate a key pair: openssl genrsa -out keys/jwt-private.pem 2048
#                      openssl rsa -in keys/jwt-private.pem -pubout -out keys/jwt-public.pem
# ---------------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ISSUER=SentinelMap
JWT_AUDIENCE=SentinelMap
