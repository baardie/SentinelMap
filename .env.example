# Database
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_dev_password
POSTGRES_DB=sentinelmap

# Redis
REDIS_URL=redis://redis:6379

# JWT (generate RSA key pair: openssl genrsa -out key.pem 2048)
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ISSUER=SentinelMap
JWT_AUDIENCE=SentinelMap

# Data Mode: Simulated | Live | Hybrid
SENTINELMAP_DATA_MODE=Simulated

# Live mode API keys (only needed for Live/Hybrid)
AISSTREAM_API_KEY=
# ADS-B (Airplanes.live) requires no key

# Seed user password override
SENTINELMAP_SEED_PASSWORD=Demo123!

# Alert thresholds (Simulated mode overrides these automatically)
AIS_DARK_TIMEOUT_SECONDS=900
