{
    auto_https disable_redirects
}

:80 {
    handle /api/* {
        reverse_proxy api:5000
    }

    handle /hubs/* {
        reverse_proxy api:5000
    }

    handle /swagger/* {
        reverse_proxy api:5000
    }

    handle /health {
        reverse_proxy api:5000
    }

    handle {
        reverse_proxy web:80
    }

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://protomaps.github.io; connect-src 'self' ws: wss: https://protomaps.github.io; worker-src 'self' blob:; font-src 'self' https://protomaps.github.io;"
    }
}
